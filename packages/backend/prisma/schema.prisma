generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  slackUserId String   @unique @map("slack_user_id")
  teamId      String   @map("team_id")
  displayName String   @map("display_name")
  realName    String   @map("real_name")
  avatarUrl   String?  @map("avatar_url")
  isApproved  Boolean  @default(false) @map("is_approved")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages  Message[]
  bookmarks Bookmark[]

  @@map("users")
}

model Channel {
  id          String   @id @default(cuid())
  slackId     String   @unique @map("slack_id")
  name        String
  description String?
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages Message[]

  @@map("channels")
}

model Message {
  id           String  @id @default(cuid())
  slackTs      String  @map("slack_ts")
  channelId    String  @map("channel_id")
  slackUserId  String? @map("slack_user_id") // Slack生のuser_id（バックフィル用）
  userId       String? @map("user_id")
  text         String
  threadTs     String? @map("thread_ts")
  replyCount   Int     @default(0) @map("reply_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  channel   Channel    @relation(fields: [channelId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])
  files     File[]
  bookmarks Bookmark[]

  @@unique([channelId, slackTs])
  @@index([channelId])
  @@index([threadTs])
  @@index([userId])
  @@map("messages")
}

model File {
  id        String   @id
  messageId String   @map("message_id")
  slackUrl  String   @map("slack_url")
  backupUrl String?  @map("backup_url")
  mimeType  String?  @map("mime_type")
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id])

  @@map("files")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  messageId String   @map("message_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id])

  @@unique([userId, messageId])
  @@map("bookmarks")
}
